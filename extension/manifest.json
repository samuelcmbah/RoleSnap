{
  "manifest_version": 3,
  "name": "RoleSnap",
  "version": "1.0.0",
  "description": "Save job posts from anywhere — WhatsApp, LinkedIn, Twitter — with one right-click.",

  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "scripting",
    "notifications"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "index.html",
    "default_title": "RoleSnap"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}